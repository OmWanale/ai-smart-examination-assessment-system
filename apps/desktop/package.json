{
  "name": "quiz-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "public/main.js",
  "homepage": "./",
  "author": "Quiz Team",
  "description": "AI Smart Examination & Assessment System - Desktop Application",
  "scripts": {
    "start": "electron .",
    "electron:dev": "npm --prefix ../frontend run build && electron .",
    "build:frontend": "npm --prefix ../frontend run build",
    "build": "npm run build:frontend && electron-builder --win --x64",
    "build:portable": "npm run build:frontend && electron-builder --win portable --x64",
    "dist": "npm run build",
    "electron:build": "npm run build:frontend && electron-builder",
    "electron:build:win": "npm run build:frontend && electron-builder --win",
    "electron:build:all": "npm run build:frontend && electron-builder -mwl"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.ai-smart-exam.desktop",
    "productName": "AI Smart Exam System",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "public/main.js",
      "public/preload.js",
      "node_modules/**/*",
      "!node_modules/**/node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "frontend-build",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Smart Exam System"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
